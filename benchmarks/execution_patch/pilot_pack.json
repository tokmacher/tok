    {
      "id": "exec.click.option-precedence",
      "family": "execution_patch",
      "title": "Repair option precedence without regressing help or parsing",
      "summary": "Fix a regression where defaults, environment-derived values, and explicit flags no longer resolve in the intended order.",
      "repo": "pallets/click",
      "ref": "8.1.7",
      "setup_script": "python -m pip install -e . --no-deps",
      "prompt": "A recent regression changed how command-line defaults, environment-provided values, and explicit flags interact. Repair the bug, preserve unrelated help and parsing behavior, and run the most relevant tests before finishing.",
      "allowed_tools": [
        "list_dir",
        "grep_search",
        "view_file",
        "edit_file",
        "run_tests",
        "git_diff"
      ],
      "time_budget_minutes": 15,
      "step_budget": 60,
      "success_evaluator": {
        "kind": "execution_patch",
        "allowed_path_check": true,
        "clean_exit_required": true,
        "hidden_tests_timeout_seconds": 60,
        "hidden_evaluator_ref": "exec.click.option-precedence"
      },
      "artifact_policy": {
        "publish_diff": true,
        "publish_hidden_tests": false,
        "publish_runtime_log": true
      },
      "public_release": true,
      "prompt_forbidden_terms": [
        "src/click/core.py",
        "ParameterSource",
        "value_from_envvar"
      ],
      "allowed_paths": [
        "src/click/core.py",
        "src/click/parser.py",
        "tests/test_context.py"
      ],
      "visible_tests": [
        "tests/test_context.py::test_parameter_source"
      ],
      "hidden_tests": [],
      "asset_dir": "assets/exec.click.option-precedence",
      "workspace_source": {
        "kind": "asset_snapshot",
        "path": "assets/exec.click.option-precedence/workspace"
      },
      "seed_patch": "seed.patch",
      "family_payload": {
        "allowed_paths": [
          "src/click/core.py",
          "src/click/parser.py",
          "tests/test_context.py"
        ],
        "visible_tests": [
          "tests/test_context.py::test_parameter_source"
        ],
        "seed_patch_path": "seed.patch",
        "seed_patch_edits": [
          {
            "path": "src/click/core.py",
            "old_string": "if value is None:\n            value = self.value_from_envvar(ctx)\n            source = ParameterSource.ENVIRONMENT",
            "new_string": "if not value:\n            value = self.value_from_envvar(ctx)\n            source = ParameterSource.ENVIRONMENT"
          }
        ]
      }
